{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "openrouter/google/gemini-flash-latest",
  "subagent_depth": 3,
  "snapshot": true,
  "formatter": true,
  "lsp": true,
  "tool_output": {
    "max_lines": 5000,
    "max_bytes": 204800
  },
  "compaction": {
    "auto": true,
    "tail_turns": 12,
    "prune": false,
    "reserved": 20000,
    "preserve_recent_tokens": 20000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", "build/**", ".next/**", ".git/**", "target/**", ".cache/**", "__pycache__/**", ".venv/**", "coverage/**"]
  },
  "experimental": {
    "batch_tool": true,
    "continue_loop_on_deny": true
  },
  "permission": {
    "*": "allow",
    "external_directory": "allow",
    "doom_loop": "allow"
  },
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "steps": 200,
      "temperature": 0.2
    },
    "plan": {
      "mode": "primary",
      "steps": 100
    }
  }
}
