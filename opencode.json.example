{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "build",
  "snapshot": true,
  "subagent_depth": 3,
  "instructions": ["AGENTS.md"],
  "formatter": true,
  "lsp": true,
  "tool_output": {
    "max_lines": 5000,
    "max_bytes": 204800
  },
  "compaction": {
    "auto": true,
    "tail_turns": 12,
    "prune": false,
    "reserved": 20000,
    "preserve_recent_tokens": 20000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", "build/**", ".next/**", ".git/**", "target/**", ".cache/**", "__pycache__/**", ".venv/**", "coverage/**"]
  },
  "experimental": {
    "batch_tool": true,
    "continue_loop_on_deny": true
  },
  "permission": {
    "*": "allow",
    "external_directory": "allow",
    "doom_loop": "allow"
  },
  "agent": {
    "build": {
      "mode": "primary",
      "description": "High-autonomy build agent - ships features end-to-end, fixes tests/lint/types autonomously",
      "steps": 200,
      "temperature": 0.2
    },
    "autonomous": {
      "mode": "primary",
      "description": "Closed-loop SHIP agent: concept -> spec -> plan -> decompose -> implement -> verify -> fix -> ship",
      "steps": 300,
      "temperature": 0.2,
      "permission": {
        "*": "allow",
        "external_directory": "allow",
        "doom_loop": "allow"
      }
    },
    "specifier": {
      "mode": "subagent",
      "description": "Creates SHIP SPEC and machine-checkable DoD artifacts with oracle commands",
      "steps": 120,
      "temperature": 0.15,
      "permission": {
        "*": "allow",
        "external_directory": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "description": "Planning and analysis - read-only with ask for edits",
      "steps": 100,
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "write": "ask",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "external_directory": "allow",
        "task": "allow"
      }
    }
  },
  "provider": {
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  }
}
