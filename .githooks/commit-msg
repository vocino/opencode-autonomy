#!/bin/sh
# Block Co-authored-by: Cursor trailers
if grep -qi "Co-authored-by:.*Cursor" "$1"; then
  echo "ERROR: Blocking commit with Cursor Co-authored-by trailer"
  exit 1
fi
# Strip cursoragent attribution if present (safety)
sed -i '/Co-authored-by:.*cursoragent@cursor/d' "$1" 2>/dev/null || true
sed -i '/Co-authored-by:.*Cursor/d' "$1" 2>/dev/null || true
